# ============================================================
# Mwijay AI Voice Studio — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# The app works without Firebase — all core features
# (STT, TTS, memory) use Puter.js and localStorage.
# ============================================================

# ─── Firebase (Optional — for cloud sync) ───────────────────
# Get these from: Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── AI Provider Configuration ────────────────────────────
# Puter.js is the primary AI provider (no API key needed)
NEXT_PUBLIC_USE_PUTER=true
NEXT_PUBLIC_DEFAULT_AI_PROVIDER=puter
NEXT_PUBLIC_DEFAULT_AI_MODEL=gpt-4o-mini

# ─── Future AI Provider Fallbacks (Optional) ──────────────
# These will be used in future prompts for provider rotation
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
HUGGINGFACE_API_KEY=

# ─── Cloudinary (Optional — for media uploads) ───────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ─── Email / Monitoring / Analytics (Optional) ───────────
RESEND_API_KEY=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=