{
  "name": "mwijay-tech",
  "version": "1.0.0",
  "description": "Mwijay Tech - AI Voice Studio Desktop App",
  "author": "Mwijay Tech <mwijaytech@example.com>",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "export": "cross-env BUILD_FOR_ELECTRON=true next build",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run export && electron-builder",
    "electron:build:win": "npm run export && electron-builder --win",
    "electron:build:mac": "npm run export && electron-builder --mac",
    "electron:build:linux": "npm run export && electron-builder --linux"
  },
  "build": {
    "appId": "com.mwijaytech.app",
    "productName": "Mwijay Tech",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.svg",
      "artifactName": "MwijayTech-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.svg",
      "artifactName": "MwijayTech-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.svg",
      "artifactName": "MwijayTech-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "language": "1033"
    }
  },
  "publish": {
    "provider": "github",
    "owner": "mwijay12",
    "repo": "techymwijay"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.23",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-avatar": "^1.2.4",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-progress": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.16",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-separator": "^1.1.13",
    "@radix-ui/react-switch": "^1.3.5",
    "@radix-ui/react-tabs": "^1.1.19",
    "@radix-ui/react-toast": "^1.2.21",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "@tailwindcss/typography": "^0.5.20",
    "@tsparticles/react": "^4.1.3",
    "@tsparticles/slim": "^4.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "color-bits": "^1.1.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.0.0",
    "fuse.js": "^7.5.0",
    "groq-sdk": "^1.3.0",
    "lucide-react": "^0.344.0",
    "motion": "^12.40.0",
    "next": "^14.2.0",
    "openai": "^6.48.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "firebase": "^12.15.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
